; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="ByteBound"
run/main_scene="uid://dj33b6ynfouwy"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Assets/icon.svg"

[audio]

buses/default_bus_layout="uid://db1cuc6612v1x"

[autoload]

BeehaveGlobalMetrics="*uid://c3ktl6ontsdt7"
BeehaveGlobalDebugger="*uid://bl3ma400hpvsh"
SignalHub="*res://autoloads/signal_hub.gd"
SceneManager="*res://autoloads/scene_manager.gd"
Debug="*res://autoloads/debug.gd"
AudioSettings="*res://autoloads/audio_settings.gd"
AudioPool="*uid://dcsi4iu45tfjv"
CutsceneManager="*res://autoloads/cutscene_manager.gd"
PortalRegistry="*uid://ctm1o53g3recg"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="ByteBound"

[editor_plugins]

enabled=PackedStringArray("res://addons/audio-pool/plugin.cfg", "res://addons/beehave/plugin.cfg", "res://addons/gut/plugin.cfg", "res://addons/state_machine/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "orange",
"res://Assets/Objects/Barriers/BlueBeam/": "blue",
"res://Assets/Objects/Barriers/GreenBeam/": "green",
"res://Assets/Objects/Barriers/RedBeam/": "red",
"res://Assets/Objects/Buttons/BluePedistal/": "blue",
